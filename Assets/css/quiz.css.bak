/* Quiz styles for JambQuiz (uses site variables for colors) */
.quiz-wrap{max-width:980px;margin:20px auto;padding:18px;background:var(--card);border:1px solid rgba(10,30,20,0.04);border-radius:8px;font-family:Inter, Poppins, Arial,Helvetica,sans-serif}
.quiz-header{display:flex;justify-content:space-between;align-items:center;gap:12px}
.quiz-title{font-size:1.3rem;font-weight:700;color:var(--oae-dark)}
.subject-list{display:flex;flex-wrap:wrap;gap:10px;margin:12px 0}
.subject-item{display:flex;align-items:center;gap:8px}
.options{margin-top:12px}
.question-card{padding:14px;border-radius:6px;border:1px solid rgba(0,0,0,0.03);margin-bottom:12px;background:linear-gradient(180deg,var(--card), #fbfffb)}
.option{display:block;padding:10px;border-radius:6px;border:1px solid transparent;margin-bottom:8px;cursor:pointer;background:transparent}
.option:hover{border-color:rgba(0,0,0,0.06);background:rgba(27,111,82,0.03)}
.option.selected{background:linear-gradient(90deg, rgba(111,214,200,0.16), rgba(43,127,116,0.08));border-color:rgba(31,185,128,0.12)}
.footer-bar{display:flex;justify-content:space-between;align-items:center;margin-top:12px;flex-wrap:wrap;gap:8px}
.btn{background:linear-gradient(90deg,green,var(--oae-dark));color:white;padding:10px 14px;border-radius:6px;text-decoration:none;display:inline-block;border:0;cursor:pointer;font-weight:700}
.btn:hover{opacity:0.9}
.btn.secondary{background:transparent;border:1.5px solid var(--oae-dark);color:var(--oae-dark)}
.btn-nav{padding:8px 4px;font-size:0.85rem;background:transparent;border:1px solid rgba(0,0,0,0.1);border-radius:4px;cursor:pointer;font-weight:600}
.btn-nav:hover{background:rgba(0,0,0,0.03);border-color:var(--oae-dark)}
.timer{font-weight:700;color:var(--oae-dark)}
.progress{height:10px;background:rgba(0,0,0,0.04);border-radius:6px;overflow:hidden;width:100%}
.progress > i{display:block;height:100%;background:linear-gradient(90deg,var(--oae-green),var(--oae-dark));width:0%}
.badge{display:inline-block;padding:6px 10px;background:linear-gradient(90deg, rgba(111,214,200,0.12), rgba(43,127,116,0.08));border-radius:20px;color:var(--oae-dark);margin-left:8px;font-weight:700}
.review-correct{background:rgba(134,237,193,0.12);border-color:rgba(79,195,152,0.14)}
.review-wrong{background:rgba(255,200,200,0.08);border-color:rgba(255,120,120,0.12)}
.score-card{background:linear-gradient(180deg, rgba(111,214,200,0.08), rgba(43,127,116,0.04));border:1px solid rgba(31,185,128,0.1);border-radius:8px;padding:16px;text-align:center}
.score-label{color:var(--muted);font-size:0.85rem;font-weight:700;text-transform:uppercase;margin-bottom:8px}
.score-value{font-size:2.2rem;font-weight:800;color:var(--oae-dark);line-height:1}
.score-detail{color:var(--muted);font-size:0.9rem;margin-top:6px}
.small{font-size:0.9rem;color:var(--muted)}
.center{text-align:center}
.note{font-size:0.95rem;color:var(--oae-dark)}
@media (max-width:720px){.quiz-header{flex-direction:column;align-items:flex-start}.quiz-wrap{margin:8px}.score-value{font-size:1.8rem}}
