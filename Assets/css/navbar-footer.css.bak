/* ========= OAE THEME & SHARED STYLES =========*/
:root{
  /* OAE color tokens (exact brand map) */
  --oae-green: green;
  --oae-green-dark: darkgreen;
  --white: #FFFFFF;
  --bg: #FFFFFF;
  --bg-contrast: #F9F9F9;
  --footer-dark: #1F1F1F;
  --footer-text: #FFFFFF;
  --text-main: #212529;
  --text-secondary: #6C757D;
  --heading-color: darkgreen;
  --input-border: #CED4DA;
  --card: #FFFFFF;
  --glass: rgba(255,255,255,0.65);
  --muted: #586068;
}

/* ===== Global Styles ===== */
html, body {
  height: 100%;
}

body {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

main {
  flex: 1;
}

footer {
  margin-top: auto;
}

* {
  box-sizing: border-box;
}

html, body {
  height: 100%;
}

body {
  margin: 0;
  font-family: Inter, "Poppins", system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
  background: var(--bg);
  color: var(--text-main);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  line-height: 1.45;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  overflow-x: hidden;
}

main {
  flex: 1;
}

/* ====== NAVBAR ====== */
.navbar {
  position: sticky;
  top: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  background: #ffffff !important;
  padding: 12px 20px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  will-change: transform;
  flex-wrap: nowrap;
  min-height: 75px;
  border-bottom: 2px solid green;
}

.brand {
  display: flex;
  gap: 8px;
  align-items: center;
  text-decoration: none;
  color: darkgreen !important;
  white-space: nowrap;
  flex-shrink: 0;
}

.logo {
  width: 130px !important;
  height: 50px !important;
  min-width: 130px !important;
  min-height: 50px !important;
  max-width: 130px !important;
  max-height: 50px !important;
  background: transparent !important;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
  border: none !important;
  box-shadow: none !important;
  padding: 0 !important;
}

.logo:hover {
  box-shadow: none !important;
}

.logo-img,
.logo-img-mobile {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 0 !important;
  border: none !important;
  border-radius: 0 !important;
}

/* Desktop logo styling */
@media (min-width: 1201px) {
  .logo {
    width: 200px !important;
    height: 50px !important;
    min-width: 200px !important;
    min-height: 50px !important;
    max-width: 200px !important;
    max-height: 50px !important;
    box-shadow: none !important;
    border-radius: 0 !important;
  }
}

/* Tablet logo styling */
@media (max-width: 1200px) {
  .logo {
    width: 170px !important;
    height: 48px !important;
    min-width: 170px !important;
    min-height: 48px !important;
    max-width: 170px !important;
    max-height: 48px !important;
    box-shadow: none !important;
    border-radius: 0 !important;
  }
}

@media (max-width: 900px) {
  .logo {
    width: 140px !important;
    height: 45px !important;
    min-width: 140px !important;
    min-height: 45px !important;
    max-width: 140px !important;
    max-height: 45px !important;
    box-shadow: none !important;
    border-radius: 0 !important;
  }
}

@media (max-width: 700px) {
  .logo {
    width: 110px !important;
    height: 42px !important;
    min-width: 110px !important;
    min-height: 42px !important;
    max-width: 110px !important;
    max-height: 42px !important;
    box-shadow: none !important;
    border-radius: 0 !important;
  }
}

@media (max-width: 560px) {
  .logo {
    width: 90px !important;
    height: 40px !important;
    min-width: 90px !important;
    min-height: 40px !important;
    max-width: 90px !important;
    max-height: 40px !important;
    box-shadow: none !important;
    border-radius: 0 !important;
  }
}

.brand h1 {
  font-size: 1.05rem;
    color: darkgreen;
  margin: 0;
  white-space: nowrap;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 20px;
  justify-content: center;
  flex: 1;
}

/* search */
.search {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--glass);
  padding: 12px 18px;
  border-radius: 999px;
  border: 1px solid rgba(20,40,30,0.06);
  min-width: 420px;
  max-width: 550px;
  width: 100%;
  flex-shrink: 0;
}

.search input {
  border: 0;
  background: transparent;
  outline: none;
  padding: 8px 12px;
  font-size: 1.05rem;
  color: green;
  width: 100%;
  min-width: 100px;
}

.search input::placeholder {
  color: #7a9a8f;
  font-size: 1.05rem;
}

.search button {
  background: green;
  border: 0;
  padding: 10px 22px;
  border-radius: 999px;
  color: var(--white);
  font-weight: 700;
  cursor: pointer;
  font-size: 1rem;
  box-shadow: 0 6px 18px rgba(40,167,69,0.14);
  white-space: nowrap;
  flex-shrink: 0;
}

.search button:hover {
  background: var(--oae-green-dark);
}

.nav-links {
  display: flex;
  gap: 8px;
  align-items: center;
  margin-left: 8px;
}

.nav-link {
  position: relative;
  padding: 6px 10px;
  border-radius: 8px;
  color: darkgreen !important;
  text-decoration: none;
  font-weight: 600;
  cursor: pointer;
  border: none;
  background: transparent;
  font-size: 0.95rem;
}

.nav-link:hover {
  background: rgba(255,255,255,0.06);
}

.nav-link-trigger {
  background: transparent;
  border: none;
  padding: 6px 10px;
  border-radius: 8px;
  color: darkgreen !important;
  font-weight: 600;
  cursor: pointer;
  font-size: 0.95rem;
}

.nav-link-trigger:hover {
  background: rgba(255,255,255,0.06);
}

.cta {
  padding: 8px 14px;
  border-radius: 8px;
  background: green;
  color: var(--white);
  border: 0;
  font-weight: 700;
  cursor: pointer;
  font-size: 0.95rem;
  white-space: nowrap;
}

.cta:hover {
  background: var(--oae-green-dark);
}

/* Secondary button style (transparent / outline) */
.btn-secondary,
.secondary {
  background: var(--bg-contrast);
  color: green;
  border: 1px solid var(--oae-green);
  padding: 8px 12px;
  border-radius: 8px;
  cursor: pointer;
}

.btn-secondary:hover,
.secondary:hover {
  background: green;
  color: var(--white);
}

/* Form inputs: borders and focus styles */
input, textarea, select {
  border: 1px solid var(--input-border);
  padding: 8px 10px;
  border-radius: 6px;
  color: var(--text-main);
  background: var(--white);
}

input:focus, textarea:focus, select:focus {
  outline: none;
  border-color: green;
  box-shadow: 0 0 0 4px rgba(40,167,69,0.08);
}

/* dropdown */
.dropdown {
  position: relative;
}

.dropdown-menu {
  position: absolute;
  top: calc(100% + 10px);
  left: 0;
  min-width: 260px;
  background: var(--card) !important;
  border-radius: 12px;
  padding: 12px;
  box-shadow: 0 12px 40px rgba(10,30,20,0.08);
  display: none;
  gap: 8px;
  border: 1px solid rgba(10,30,20,0.03);
  z-index: 1000;
}

.dropdown-menu.show {
  display: flex !important;
  flex-direction: column;
}

.menu-section {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 6px;
}

/* Explore dropdown needs to display columns side-by-side */
#explore-menu {
  display: none !important;
  min-width: auto;
  max-width: calc(100vw - 40px);
  overflow-x: auto;
  overflow-y: hidden;
}

#explore-menu.show {
  display: flex !important;
}

/* Explore menu wrapper for side-by-side layout */
#explore-menu > div {
  display: flex;
  gap: 12px;
  flex-wrap: nowrap;
}

/* Each subsection in Explore should have white background */
#explore-menu .menu-section {
  background: #ffffff !important;
  padding: 12px 10px;
  border-radius: 8px;
  min-width: 140px;
  max-width: 160px;
  flex: 0 0 auto;
}

.menu-section h4 {
  margin: 0;
  color: var(--heading-color);
  font-size: 0.95rem;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 10px;
  border-radius: 8px;
  text-decoration: none;
  color: var(--text-main) !important;
  font-weight: 600;
  cursor: pointer;
  border: none;
  background: transparent;
}

.menu-item:hover {
  background: rgba(0,0,0,0.04);
}

/* ===== FOOTER ===== */
footer {
  margin-top: auto;
  background: var(--footer-dark);
  color: var(--footer-text);
  padding: 28px 20px;
  width: 100%;
  box-sizing: border-box;
  overflow-x: hidden;
}

footer a {
  color: var(--footer-text);
  text-decoration: none;
  transition: opacity 0.3s ease;
}

footer a:hover {
  opacity: 0.9;
  text-decoration: underline;
}

.foot-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  max-width: calc(100vw - 40px);
  margin: 0 auto;
  width: 100%;
  box-sizing: border-box;
}

.foot-grid > div {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.foot-grid > div strong {
  font-size: 1.1rem;
  display: block;
  margin: 0;
}

.foot-grid > div > div {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  align-items: center;
}

.foot-grid > div > div a {
  padding: 6px 0;
}

.small {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.9);
  margin: 0;
  line-height: 1.5;
}

footer a {
  color: white;
  text-decoration: none;
  transition: opacity 0.3s ease;
}

footer a:hover {
  opacity: 0.8;
  text-decoration: underline;
}

/* ===== Mobile & small ===== */
.mobile-toggle {
  display: none;
  background: transparent;
  border: none;
  font-size: 1.8rem;
  cursor: pointer;
  color: darkgreen !important;
  padding: 10px 14px;
  flex-shrink: 0;
  z-index: 1001;
  transition: opacity 0.2s ease;
}

.mobile-toggle.active {
  opacity: 0.7;
}

.mobile-toggle:hover {
  opacity: 0.8;
}

#mobile-menu {
  display: none !important;
  position: fixed;
  right: 0;
  top: 60px;
  height: calc(100vh - 60px);
  width: 100%;
  max-width: 380px;
  background: #ffffff;
  box-shadow: -8px 0 36px rgba(10,30,20,0.12);
  z-index: 1001;
  padding: 16px 20px;
  border-radius: 0;
  box-sizing: border-box;
  overflow-y: auto;
  animation: slideInRight 0.3s ease;
  border-top: 1px solid #e0e0e0;
}

@media (max-width: 560px) {
  .navbar {
    padding: 8px 8px;
    min-height: 60px;
    gap: 8px;
  }
  
  .logo {
    width: 85px !important;
    height: 28px !important;
    min-width: 85px !important;
    min-height: 28px !important;
    max-width: 85px !important;
    max-height: 28px !important;
    flex-shrink: 0;
  }
  
  .search {
    min-width: 160px;
    max-width: 200px;
    padding: 6px 8px;
    flex-shrink: 0;
  }
  
  .search input {
    font-size: 0.85rem;
    padding: 4px 6px;
  }
  
  .search input::placeholder {
    font-size: 0.85rem;
  }
  
  .search button {
    padding: 6px 10px;
    font-size: 0.8rem;
  }
  
  .mobile-toggle {
    font-size: 1.5rem;
    padding: 6px 8px;
  }
  
  #mobile-menu {
    width: 100%;
    max-width: 100%;
    padding: 14px 16px;
  }
}

/* Disable pseudo-element backdrop - JS provides a backdrop element instead.
   Keep it off and non-interactive so it doesn't block clicks on the menu. */
#mobile-menu::before {
  content: '';
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: none !important;
  pointer-events: none !important;
}

/* Mobile menu item styling - SCOPED TO MOBILE MENU ONLY */
#mobile-menu .menu-item {
  display: block;
  width: 100%;
  padding: 12px 10px;
  background: transparent;
  border: none;
  color: darkgreen;
  text-align: left;
  cursor: pointer;
  font-size: 0.95rem;
  font-weight: 500;
  border-radius: 6px;
  transition: background 0.2s ease;
}

#mobile-menu .menu-item:hover {
  background: rgba(0, 128, 0, 0.08);
}

#mobile-menu.show::before {
  display: block;
}

@keyframes slideInRight {
  from {
    transform: translateX(100%);
  }
  to {
    transform: translateX(0);
  }
}

#mobile-menu.show {
  display: block !important;
}

/* Mobile CTA buttons inside the sliding menu should use white text for contrast */
#mobile-menu .menu-item.mobile-cta {
  color: #ffffff !important;
}

/* Provide a consistent green background for primary mobile CTAs when no inline styles used */
#mobile-menu .menu-item.mobile-cta.primary {
  background: green !important;
  color: #ffffff !important;
}

@media (max-width: 1200px) {
  .navbar {
    padding: 11px 14px;
    min-height: 72px;
    gap: 16px;
  }
  
  .logo {
    width: 140px !important;
    height: 38px !important;
    min-width: 140px !important;
    min-height: 38px !important;
    max-width: 140px !important;
    max-height: 38px !important;
    flex-shrink: 0;
  }
  
  .search {
    min-width: 350px;
    max-width: 380px;
    padding: 9px 12px;
    flex-shrink: 0;
  }
  
  .search button {
    padding: 9px 16px;
    font-size: 0.95rem;
  }
}

@media (max-width: 900px) {
  .navbar {
    padding: 10px 12px;
    min-height: 70px;
    gap: 12px;
  }
  
  .brand h1 {
    display: none;
  }
  
  .logo {
    width: 110px !important;
    height: 36px !important;
    min-width: 110px !important;
    min-height: 36px !important;
    max-width: 110px !important;
    max-height: 36px !important;
    flex-shrink: 0;
  }
  
  .search {
    min-width: 280px;
    max-width: 320px;
    padding: 8px 10px;
    flex-shrink: 0;
  }
  
  .search input {
    font-size: 0.95rem;
    padding: 6px 8px;
  }
  
  .search input::placeholder {
    font-size: 0.95rem;
  }
  
  .search button {
    padding: 8px 14px;
    font-size: 0.9rem;
  }
  
  .nav-links {
    display: none !important;
  }
  
  .mobile-toggle {
    display: block !important;
    font-size: 1.8rem;
    padding: 10px 12px;
    cursor: pointer;
    background: transparent;
    border: none;
    color: darkgreen !important;
    flex-shrink: 0;
    z-index: 1001;
  }
  
  .nav-actions {
    gap: 12px;
  }
  .foot-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }
}

@media (max-width: 700px) {
  .navbar {
    padding: 8px 10px;
    min-height: 65px;
    gap: 10px;
  }
  
  .logo {
    width: 100px !important;
    height: 32px !important;
    min-width: 100px !important;
    min-height: 32px !important;
    max-width: 100px !important;
    max-height: 32px !important;
    flex-shrink: 0;
  }
  
  .search {
    min-width: 220px;
    max-width: 260px;
    padding: 7px 10px;
    flex-shrink: 0;
  }
  
  .search input {
    font-size: 0.9rem;
    padding: 5px 8px;
  }
  
  .search input::placeholder {
    font-size: 0.9rem;
  }
  
  .search button {
    padding: 7px 12px;
    font-size: 0.85rem;
  }
  
  .mobile-toggle {
    font-size: 1.6rem;
    padding: 8px 10px;
  }
}
  
  .search input {
    font-size: 0.88rem;
    padding: 8px 5px;
  }
  
  .search button {
    padding: 8px 10px;
    font-size: 0.88rem;
  }
  
  .mobile-toggle {
    font-size: 1.8rem;
    padding: 8px 10px;
  }
  
  .nav-actions {
    gap: 6px;
  }


@media (max-width: 560px) {
  .navbar {
    background: #ffffff !important;
    padding: 8px 6px;
    gap: 6px;
    min-height: 66px;
    border-bottom: 2px solid green;
  }
  
  .logo {
    width: 75px !important;
    height: 32px !important;
    min-width: 75px !important;
    min-height: 32px !important;
    max-width: 75px !important;
    max-height: 32px !important;
    border-radius: 0 !important;
    flex-shrink: 0;
  }
  
  .brand {
    gap: 6px;
    flex-shrink: 0;
  }
  
  .brand h1 {
    display: none !important;
  }
  
  .nav-actions {
    gap: 4px;
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
  }
  
  .search {
    min-width: 100px !important;
    flex: 1;
    padding: 6px 8px !important;
    flex-shrink: 1;
    display: flex !important;
    gap: 6px;
    align-items: center;
  }
  
  .search input {
    font-size: 0.8rem !important;
    padding: 4px 6px !important;
    display: block !important;
    flex: 1;
    min-width: 60px;
  }
  
  .search button {
    padding: 5px 8px !important;
    font-size: 0.75rem !important;
    white-space: nowrap;
    display: inline-block !important;
    flex-shrink: 0;
  }
  }
  
  .search input {
    font-size: 0.85rem;
    padding: 7px 4px;
  }
  
  .search button {
    padding: 7px 9px;
    font-size: 0.85rem;
  }
  
  .mobile-toggle {
    font-size: 1.8rem !important;
    padding: 8px 10px !important;
    flex-shrink: 0;
  }
  
  .nav-actions {
    gap: 4px;
    flex-shrink: 0;
  }
  

  .navbar .brand,
  .navbar .nav-link,
  .navbar .nav-actions button,
  .navbar .nav-actions a {
    color: darkgreen !important;
  }

  .navbar .nav-link:hover {
    background: rgba(255,255,255,0.06) !important;
  }

  #mobile-menu {
    background: var(--white) !important;
  }

  #mobile-menu a,
  #mobile-menu .menu-item,
  #mobile-menu .muted,
  #mobile-menu strong {
    color: green !important;
  }
  
  .dropdown-menu {
    left: auto;
    right: 0;
    min-width: 220px;
  }
  
  footer {
    padding: 20px;
  }
  
  .foot-grid {
    grid-template-columns: 1fr;
    gap: 20px;
    padding: 0 10px;
  }
  
  .nav-link {
    font-size: 0.9rem;
    padding: 4px 8px;
  }
  
  .nav-link-trigger {
    font-size: 0.9rem;
    padding: 4px 8px;
  }


/* Utility classes */
a {
  color: green;
}

a:hover {
  color: var(--oae-green-dark);
}

.muted {
  color: var(--muted);
  font-size: 0.95rem;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}

/* ===== SOCIAL ICONS ===== */
.socials-bar {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 15px;
}

.socials-bar a {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  width: 50px !important;
  height: 50px !important;
  font-size: 24px !important;
  color: #ffffff !important;
  background: #008000 !important;
  border-radius: 50% !important;
  transition: all 0.3s ease !important;
  border: none !important;
  text-decoration: none !important;
  pointer-events: auto !important;
}

.socials-bar a i {
  color: #ffffff !important;
  font-size: 24px !important;
  pointer-events: none !important;
}

.socials-bar a:hover {
  background: #005500 !important;
  transform: scale(1.1) !important;
  color: #ffffff !important;
  text-decoration: none !important;
}

