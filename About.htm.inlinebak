<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>About OAE | Oluwatosin Academy of Excellence</title>
  <meta name="description" content="Learn about Oluwatosin Academy of Excellence (OAE) - an innovative educational platform for JAMB, WAEC, NECO, and tech careers.">
  <link rel="stylesheet" href="Assets/css/footer.css">
  <link rel="stylesheet" href="Assets/css/navbar.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Montserrat:wght@400;600;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="Assets/css/layout.css">
  <style>
    /* Advanced Animations */
    @keyframes bounce-in {
      0% { transform: scale(0.3); opacity: 0; }
      50% { transform: scale(1.05); }
      70% { transform: scale(0.9); }
      100% { transform: scale(1); opacity: 1; }
    }

    @keyframes bounce-up {
      0% { transform: translateY(30px); opacity: 0; }
      60% { transform: translateY(-10px); opacity: 1; }
      100% { transform: translateY(0); }
    }

    @keyframes bounce-left {
      0% { transform: translateX(-30px); opacity: 0; }
      60% { transform: translateX(10px); opacity: 1; }
      100% { transform: translateX(0); }
    }

    @keyframes fade-bounce {
      0% { opacity: 0; transform: translateY(20px) scale(0.9); }
      50% { opacity: 0.5; transform: translateY(-5px) scale(1.02); }
      100% { opacity: 1; transform: translateY(0) scale(1); }
    }

    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-20px); }
    }

    @keyframes slide-in-right {
      0% { transform: translateX(100px); opacity: 0; }
      100% { transform: translateX(0); opacity: 1; }
    }

    @keyframes pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.05); }
      100% { transform: scale(1); }
    }

    @keyframes gradient-shift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    /* Background Effects */
    body {
      background: linear-gradient(-45deg, #f8fdf9, #e6f7e9, #d4f0d9, #f0f9f0);
      background-size: 400% 400%;
      animation: gradient-shift 15s ease infinite;
      min-height: 100vh;
    }

    .floating-shapes {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: -1;
      overflow: hidden;
    }

    .shape {
      position: absolute;
      border-radius: 50%;
      background: linear-gradient(45deg, lightgreen, darkgreen);
      animation: float 6s ease-in-out infinite;
    }

    .shape:nth-child(1) {
      width: 80px;
      height: 80px;
      top: 10%;
      left: 10%;
      animation-delay: 0s;
    }

    .shape:nth-child(2) {
      width: 60px;
      height: 60px;
      top: 20%;
      right: 10%;
      animation-delay: 2s;
    }

    .shape:nth-child(3) {
      width: 100px;
      height: 100px;
      bottom: 20%;
      left: 20%;
      animation-delay: 4s;
    }

    .shape:nth-child(4) {
      width: 70px;
      height: 70px;
      bottom: 10%;
      right: 20%;
      animation-delay: 1s;
    }

    .shape:nth-child(5) {
      width: 90px;
      height: 90px;
      top: 50%;
      left: 50%;
      animation-delay: 3s;
    }

    /* Animation Classes */
    .bounce-in {
      animation: bounce-in 1.2s ease-out;
    }

    .bounce-up {
      animation: bounce-up 1s ease-out 0.3s both;
    }

    .bounce-left {
      animation: bounce-left 1s ease-out 0.6s both;
    }

    .fade-bounce {
      animation: fade-bounce 1.5s ease-out 0.9s both;
    }

    .slide-in-right {
      animation: slide-in-right 1s ease-out 1.2s both;
    }

    .float-animation {
      animation: float 3s ease-in-out infinite;
    }

    .pulse-animation {
      animation: pulse 2s infinite;
    }

    /* Enhanced Typography & Layout */
    .about-content {
      font-size: clamp(1rem, 2.5vw, 1.3rem);
      line-height: 1.8;
      color: #333;
      margin-bottom: 2rem;
      position: relative;
    }

    .about-content p {
      margin-bottom: 2rem;
      text-align: justify;
      padding: 1.5rem 2rem;
      background: rgba(255, 255, 255, 0.8);
      border-radius: 15px;
      box-shadow: 0 8px 32px rgba(10, 138, 47, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      transition: all 0.3s ease;
    }

    .about-content p:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 40px rgba(10, 138, 47, 0.15);
    }

    .about-content .highlight {
      background: linear-gradient(120deg, #28A745 0%, #28A745 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-weight: 700;
      position: relative;
      display: inline-block;
    }

    /* Decorative Elements */
    .decorative-quote {
      position: relative;
      padding: 2rem;
      margin: 3rem 0;
      background: linear-gradient(135deg, rgba(10, 138, 47, 0.05), rgba(6, 100, 38, 0.05));
      border-radius: 20px;
      border-left: 5px solid green;
      font-style: italic;
      text-align: center;
      color: darkgreen;
      font-size: 1.2rem;
      font-weight: 500;
    }

    .decorative-quote::before {
      content: '"';
      position: absolute;
      top: -10px;
      left: 20px;
      font-size: 4rem;
      color: rgba(10, 138, 47, 0.2);
      font-family: serif;
    }

    .decorative-quote::after {
      content: '"';
      position: absolute;
      bottom: -30px;
      right: 20px;
      font-size: 4rem;
      color: rgba(10, 138, 47, 0.2);
      font-family: serif;
    }

    .feature-highlight {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin: 1.5rem 0;
      padding: 1rem;
      background: rgba(255, 255, 255, 0.7);
      border-radius: 12px;
      border: 2px solid rgba(10, 138, 47, 0.1);
      transition: all 0.3s ease;
    }

    .feature-highlight:hover {
      border-color: rgba(10, 138, 47, 0.3);
      background: rgba(255, 255, 255, 0.9);
      transform: translateX(10px);
    }

    .feature-icon {
      font-size: 2.5rem;
      color: green;
      min-width: 60px;
      text-align: center;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .feature-text {
      flex: 1;
      margin: 0;
    }

    .mission-statement {
      background: #FFFFFF;
      padding: 2.5rem;
      border-radius: 20px;
      text-align: center;
      margin: 3rem 0;
      position: relative;
      overflow: hidden;
      animation: fadeInUp 1s ease-out;
    }

    .mission-statement::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="25" cy="25" r="1" fill="rgba(40,167,69,0.1)"/><circle cx="75" cy="75" r="1" fill="rgba(40,167,69,0.1)"/><circle cx="50" cy="10" r="0.5" fill="rgba(40,167,69,0.1)"/><circle cx="10" cy="50" r="0.5" fill="rgba(40,167,69,0.1)"/><circle cx="90" cy="50" r="0.5" fill="rgba(40,167,69,0.1)"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
      opacity: 0.3;
    }

    .mission-statement h3 {
      margin-bottom: 1rem;
      font-size: 1.8rem;
      position: relative;
      z-index: 1;
      color: green;
      font-weight: bold;
      font-family: 'Poppins', 'Montserrat', 'Roboto', sans-serif;
    }

    .mission-statement p {
      border: 1px solid green;
      font-size: 1.1rem;
      line-height: 1.7;
      margin: 0 0 1rem 0;
      position: relative;
      z-index: 1;
      color: green;
      font-family: 'Poppins', 'Montserrat', 'Roboto', sans-serif;
      animation: fadeInUp 1s ease-out;
    }

    .mission-statement p:nth-child(2) {
      animation-delay: 0.2s;
    }

    .mission-statement p:nth-child(3) {
      animation-delay: 0.4s;
    }

    .mission-statement p:nth-child(4) {
      animation-delay: 0.6s;
    }

    .decorative-divider {
      height: 4px;
      background: linear-gradient(90deg, green, darkgreen, green);
      border-radius: 2px;
      margin: 2rem auto;
      width: 100px;
      position: relative;
    }

    .decorative-divider::before {
      content: '';
      position: absolute;
      top: -8px;
      left: 50%;
      transform: translateX(-50%);
      width: 20px;
      height: 20px;
      background: green;
      border-radius: 50%;
      border: 3px solid white;
      box-shadow: 0 0 0 2px darkgreen;
    }

    .about-content .emphasis {
      font-weight: 600;
      color: darkgreen;
      position: relative;
      transition: all 0.3s ease;
    }

    .about-content .emphasis:hover {
      color: green;
      transform: scale(1.05);
    }

    /* Responsive Design */
    @media (max-width: 768px) {
      .about-content p {
        padding: 1rem;
        margin-bottom: 1.5rem;
      }

      .floating-shapes .shape {
        display: none; /* Hide floating shapes on mobile for better performance */
      }

      body {
        background: linear-gradient(135deg, #f8fdf9 0%, #e6f7e9 100%);
        animation: none; /* Disable background animation on mobile */
      }

      .stat-card {
        padding: 1.5rem;
        margin-bottom: 1rem;
      }

      .stat-card div:first-child {
        font-size: 2rem;
      }

      .stat-card div:nth-child(2) {
        font-size: 1.5rem;
      }

      .decorative-quote {
        padding: 1.5rem;
        margin: 2rem 0;
        font-size: 1rem;
      }

      .decorative-quote::before,
      .decorative-quote::after {
        font-size: 2rem;
      }

      .feature-highlight {
        flex-direction: column;
        text-align: center;
        gap: 0.5rem;
      }

      .feature-icon {
        font-size: 1.5rem;
      }

      .mission-statement {
        padding: 2rem 1.5rem;
      }

      .mission-statement h3 {
        font-size: 1.5rem;
      }

      .mission-statement p {
        font-size: 0.875rem; /* 14px */
        line-height: 1.6;
      }

      /* What We Offer Mobile Styles */
      .offer-intro {
        padding: 1.5rem;
        margin: 1.5rem 0;
      }

      .offering-card {
        padding: 1.5rem;
        margin: 0.8rem 0;
      }

      .offering-header {
        flex-direction: column;
        text-align: center;
        gap: 0.8rem;
      }

      .offering-icon {
        margin-right: 0;
        margin-bottom: 0.5rem;
      }

      /* Call to Action Responsive */
      .cta-section {
        padding: 2rem 1.5rem !important;
      }

      .cta-section h3 {
        font-size: 1.8rem !important;
      }

      .cta-section p {
        font-size: 1.1rem !important;
      }

      .cta-section button {
        padding: 0.8rem 1.5rem !important;
        font-size: 1rem !important;
        margin: 0.5rem !important;
      }
    }

    @media (max-width: 480px) {
      .about-content {
        font-size: 1rem;
      }

      .about-content p {
        padding: 0.8rem;
        text-align: left;
      }

      .stat-card {
        padding: 1rem;
      }

      .stat-card div:first-child {
        font-size: 1.8rem;
      }

      .stat-card div:nth-child(2) {
        font-size: 1.3rem;
      }

      .decorative-quote {
        padding: 1rem;
        font-size: 0.9rem;
      }

      .feature-highlight {
        padding: 0.8rem;
      }

      .mission-statement {
        padding: 1.5rem 1rem;
      }

      .mission-statement h3 {
        font-size: 1.3rem;
      }

      /* Call to Action Responsive */
      .cta-section {
        padding: 2rem 1rem !important;
      }

      .cta-section h3 {
        font-size: 1.5rem !important;
      }

      .cta-section p {
        font-size: 1rem !important;
      }

      .cta-section .cta-buttons {
        flex-direction: column !important;
        align-items: center !important;
      }

      .cta-section button {
        width: 100% !important;
        max-width: 250px !important;
        padding: 1rem !important;
        font-size: 1rem !important;
        margin: 0.5rem 0 !important;
      }
    }

    /* Desktop Enhancements */
    @media (min-width: 769px) {
      .about-content p {
        padding: 2rem 2.5rem;
        font-size: 1.15rem;
      }

      .feature-highlight {
        padding: 1.5rem;
        margin: 1rem 0;
      }

      .decorative-quote {
        padding: 2.5rem;
        font-size: 1.2rem;
      }

      .mission-statement {
        padding: 3rem 2.5rem;
      }

      .stat-card {
        padding: 2.5rem;
      }
    }

    /* Desktop Enhancements */
    @media (min-width: 769px) {
      .about-content p {
        padding: 2rem 2.5rem;
        font-size: 1.15rem;
      }

      .feature-highlight {
        padding: 1.5rem;
        margin: 1rem 0;
      }

      .decorative-quote {
        padding: 2.5rem;
        font-size: 1.2rem;
      }

      .mission-statement {
        padding: 3rem 2.5rem;
      }

      /* What We Offer Desktop Styles */
      .offerings-grid {
        grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
        gap: 2rem;
      }

      .offering-card {
        padding: 2.5rem;
      }

      .offering-header h4 {
        font-size: 1.4rem;
      }

      /* Who We Serve Desktop Styles */
      .audience-grid {
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
      }

      .audience-card {
        padding: 2.5rem;
      }

      .audience-header h4 {
        font-size: 1.4rem;
      }

      /* OAE Platform Features Desktop Styles */
      .features-grid {
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 2rem;
      }

      .feature-card {
        padding: 2.5rem;
      }

      .feature-header h4 {
        font-size: 1.4rem;
      }
    }
    .scroll-reveal {
      opacity: 0;
      transform: translateY(50px);
      transition: all 0.6s ease-out;
    }

    .scroll-reveal.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* Interactive Elements */
    .interactive-card {
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .interactive-card:hover {
      transform: translateY(-10px) rotate(1deg);
    }

    /* Stats Cards */
    .stat-card {
      background: rgba(255, 255, 255, 0.9);
      padding: 2rem;
      border-radius: 15px;
      box-shadow: 0 8px 32px rgba(10, 138, 47, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      transition: all 0.3s ease;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .stat-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(10, 138, 47, 0.1), transparent);
      transition: left 0.5s;
    }

    .stat-card:hover::before {
      left: 100%;
    }

    .stat-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 20px 40px rgba(10, 138, 47, 0.2);
    }

    .stat-card div:first-child {
      font-size: 3rem;
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 60px;
    }

    .stat-card div:nth-child(2) {
      font-size: 2rem;
      font-weight: 700;
      color: #212121;
      margin-bottom: 5px;
    }

    .stat-card div:nth-child(3) {
      color: #666;
      font-size: 0.9rem;
    }

    /* What We Offer Section Styles */
    .what-we-offer-section {
      margin: 3rem 0;
    }

    .section-title {
      position: relative;
    }

    .offer-intro {
      max-width: 800px;
      margin: 2rem auto;
    }

    .offerings-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin: 2rem 0;
    }

    .offering-card {
      position: relative;
      overflow: hidden;
    }

    .offering-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 35px rgba(10, 138, 47, 0.15);
    }

    .offering-header {
      margin-bottom: 1rem;
    }

    .offering-icon {
      transition: all 0.3s ease;
    }

    .offering-card:hover .offering-icon {
      transform: scale(1.1);
      box-shadow: 0 8px 20px darkgreen;
    }

    /* Audience Cards Styles */
    .audience-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin: 2rem 0;
    }

    .audience-card {
      position: relative;
      overflow: hidden;
    }

    .audience-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 35px rgba(10, 138, 47, 0.15);
    }

    .audience-header {
      margin-bottom: 1rem;
    }

    .audience-icon {
      transition: all 0.3s ease;
    }

    .audience-card:hover .audience-icon {
      transform: scale(1.1);
      box-shadow: 0 8px 20px rgba(10, 138, 47, 0.3);
    }

    /* Feature Cards Styles */
    .features-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin: 2rem 0;
    }

    .feature-card {
      position: relative;
      overflow: hidden;
    }

    .feature-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 35px rgba(10, 138, 47, 0.15);
    }

    .feature-header {
      margin-bottom: 1rem;
    }

    .feature-icon {
      transition: all 0.3s ease;
    }

    .feature-card:hover .feature-icon {
      transform: scale(1.1);
      box-shadow: 0 8px 20px rgba(10, 138, 47, 0.3);
    }

    /* Community Cards Styles */
    .community-card {
      position: relative;
      overflow: hidden;
    }

    .community-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 35px rgba(10, 138, 47, 0.15);
    }

    .card-icon {
      transition: all 0.3s ease;
    }

    .community-card:hover .card-icon {
      transform: scale(1.1);
    }

    /* Main Section Styles */
    .main-section {
      padding: 20px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .main-heading {
      font-size: clamp(1.5rem, 4vw, 2.5rem);
      color: green;
      margin: 20px 0 30px;
      text-align: center;
      position: relative;
    }

    .main-heading-underline {
      position: absolute;
      bottom: -10px;
      left: 50%;
      transform: translateX(-50%);
      width: 100px;
      height: 4px;
      background: linear-gradient(90deg, green, darkgreen);
      border-radius: 2px;
      animation: slide-in-right 1s ease-out 1.5s both;
    }

    .offer-section-title {
      font-size: clamp(1.8rem, 3vw, 2.2rem);
      color: #212121;
      text-align: center;
      margin: 40px 0 20px;
      position: relative;
    }

    .offer-title-underline {
      position: absolute;
      bottom: -8px;
      left: 50%;
      transform: translateX(-50%);
      width: 120px;
      height: 4px;
      background: linear-gradient(90deg, green, darkgreen);
      border-radius: 2px;
    }

    .offer-intro {
      background: rgba(255, 255, 255, 0.9);
      padding: 2rem;
      border-radius: 15px;
      margin: 2rem 0;
      text-align: center;
      border-left: 4px solid green;
    }

    .offer-intro p {
      font-size: 1.1rem;
      line-height: 1.7;
      margin: 0;
      color: black;
    }

    .offering-card {
      background: rgba(255, 255, 255, 0.9);
      padding: 2rem;
      border-radius: 15px;
      margin: 1rem 0;
      border: 1px solid rgba(40, 167, 69, 0.1);
      box-shadow: 0 8px 25px rgba(40, 167, 69, 0.08);
      transition: all 0.3s ease;
    }

    .offering-header {
      display: flex;
      align-items: center;
      margin-bottom: 1rem;
    }

    .offering-icon {
      background: linear-gradient(135deg, green, darkgreen);
      color: white;
      width: 50px;
      height: 50px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-right: 1rem;
      font-size: 1.2rem;
    }

    .offering-title {
      color: black;
      margin: 0;
      font-size: 1.3rem;
    }

    .offering-text {
      color: black;
      line-height: 1.6;
      margin: 0;
    }

  </style>
  <script defer src="Assets/js/animations.js"></script>
  <script defer src="Assets/js/enhance-ui.js"></script>
</head>
<body>  <!-- Floating Background Shapes -->
  <div class="floating-shapes">
    <div class="shape"></div>
    <div class="shape"></div>
    <div class="shape"></div>
    <div class="shape"></div>
    <div class="shape"></div>
  </div>
  <!-- Fixed Sticky Navbar -->
    <nav class="navbar">
        <!-- Logo - Left side -->
        <div class="logo-section">
                <img src="/OAE.png" alt="OAE"class="logoimg">
        </div>

        <!-- Search Section - Middle -->
        <div class="middle-section">
            <div class="search-section">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search lessons, exams, careers...">
                <button class="search-btn">Search</button>
            </div>
        </div>

        <!-- Right Navigation Section - Right side -->
        <div class="right-section">
            <!-- Desktop Navigation Links - TEXT BEFORE ICONS -->
            <ul class="nav-links">
